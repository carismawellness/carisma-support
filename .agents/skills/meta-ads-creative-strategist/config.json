{
  "name": "meta-ads-creative-strategist",
  "type": "skill",
  "description": "Plans creative concepts for static images, videos, carousels, and Reels/Stories across all 3 Carisma brands. Develops hook strategies, A/B testing frameworks, visual direction briefs, and seasonal creative rotation calendars informed by performance data.",
  "version": "1.0.0",
  "author": "Carisma",
  "user-invocable": false,
  "allowed-tools": "Bash, Read, Write, Edit, Glob, Grep, Task, ToolSearch",
  "metadata": {
    "agent-role": "Meta Ads Creative Strategist",
    "reports-to": "Meta Strategist",
    "runtime": "Claude Haiku",
    "org-layer": "Meta Ads Sub-Team",
    "tags": ["meta-ads", "creative-strategy", "visual-direction", "ab-testing", "hook-strategy", "video-ads", "carousel", "reels"],
    "triggers": ["creative concept", "creative strategy", "visual direction", "A/B test plan", "creative refresh", "hook strategy", "production brief", "creative fatigue", "quarterly creative"]
  },
  "execution": {
    "timeout": 300,
    "environment": "node"
  },
  "integrations": {
    "reads": ["config/brands.json", "config/offers.json", "config/kpi_thresholds.json", "config/naming_conventions.json", "config/performance_marketing_angles.md"],
    "mcp_servers": ["meta-ads", "google-workspace"]
  }
}
