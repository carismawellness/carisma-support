{
  "name": "crmrespond",
  "type": "skill",
  "description": "Generate brand-validated customer responses with automatic skill routing and validation",
  "version": "1.0",
  "author": "Carisma CRM",
  "inputs": {
    "customer_message": {
      "type": "string",
      "description": "Full customer message to respond to",
      "required": true
    },
    "brand": {
      "type": "string",
      "enum": ["AES", "SPA", "SLIM"],
      "description": "Optional: override brand detection. Auto-detects from folder if not provided",
      "required": false
    }
  },
  "outputs": {
    "status": {
      "type": "string",
      "description": "READY_TO_SEND, NEEDS_REVISION, or ERROR"
    },
    "brand": {
      "type": "string",
      "description": "Brand detected/used"
    },
    "skill_used": {
      "type": "string",
      "description": "Which of 14 skills was routed to"
    },
    "response": {
      "type": "string",
      "description": "Generated response text"
    },
    "validation_score": {
      "type": "number",
      "description": "0-100, must be ≥85 for READY_TO_SEND"
    },
    "violations": {
      "type": "array",
      "description": "List of validation violations (if any)"
    }
  },
  "execution": {
    "timeout": 30,
    "environment": "node",
    "requires_context": ["brand-voice.md", "brand-voice-validation-rules.json", "14 skill files"]
  },
  "integrations": {
    "loads_from": "Current brand folder (CRM-AES/CRM-SPA/CRM-SLIM)",
    "reads": ["CLAUDE.md", "knowledge/brand-voice.md", "hooks/brand-voice-validation-rules.json", "skills/*.md"],
    "validates_against": "brand-voice-validation-rules.json"
  }
}
