  "constraints": {
    "technical": [
      "Zoho CRM calendar cannot filter by location (custom interface needed)",
      "Must maintain consistency across 8+ integrated systems",
      "Real-time or near-real-time sync for staff availability",
      "Support for 10+ locations without performance degradation"
    ],
    "business": [
      "Cannot generate EOD reports without all treatments marked attended/cancelled",
      "Location-specific pricing, services, and staffing must be enforceable",
      "All features must support multi-location scalability"
