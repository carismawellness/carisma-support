  "api_sources": {
    "meta_ads": {
      "type": "mcp",
      "server": "meta-ads",
      "ad_accounts": {
        "carisma_spa": "act_654279452039150",
        "carisma_aesthetics": "act_382359687910745",
        "carisma_slimming": "act_1496776195316716"
      },
      "fields": ["spend", "impressions", "clicks", "actions", "cost_per_action_type", "ctr", "cpc"],
      "schedule": "every_6h"
    },
    "google_analytics": {
      "type": "mcp",
      "server": "google-analytics",
      "metrics": ["sessions", "totalUsers", "newUsers", "screenPageViews", "averageSessionDuration", "bounceRate", "conversions"],
      "schedule": "daily_6am"
    },
    "google_search_console": {
      "type": "mcp",
      "server": "google-search-console",
      "metrics": ["clicks", "impressions", "ctr", "position"],
      "schedule": "daily_6am"
    },
    "klaviyo": {
      "type": "mcp",
      "server": "klaviyo",
      "metrics": ["campaign_reports", "flow_reports", "profiles"],
      "schedule": "daily_8am"
    },
