            "statusMessage": "Deploying CEO-Cockpit to production..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; echo \"$f\" | grep -q 'Tech/CEO-Cockpit/' && cd \"/Users/mertgulen/Library/CloudStorage/GoogleDrive-mertgulen98@gmail.com/My Drive/Carisma Wellness Group/Carisma AI /Carisma AI/Tech/CEO-Cockpit\" && npx vercel --prod --yes 2>&1 | tail -5; } 2>/dev/null || true",
            "timeout": 120,
            "async": true,
