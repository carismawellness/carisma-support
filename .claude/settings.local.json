  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"/Users/mertgulen/Library/CloudStorage/GoogleDrive-mertgulen98@gmail.com/My Drive/Carisma Wellness Group/Carisma AI /Carisma AI\" && git diff --name-only HEAD~1 HEAD 2>/dev/null | grep -q \"^Tech/CEO-Cockpit/\" && (cd \"Tech/CEO-Cockpit\" && npx vercel --prod --yes 2>&1 | tail -5) || true",
